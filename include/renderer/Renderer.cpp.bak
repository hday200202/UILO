namespace uilo {

// ---- helpers ---------------------------------------------------------------

static uint32_t toABGR(Color c) {
    // BGFX colour format for clears / tints is 0xRRGGBBAA
    return (uint32_t(c.r) << 24) | (uint32_t(c.g) << 16) |
           (uint32_t(c.b) <<  8) |  uint32_t(c.a);
}

// ---- Vertex layout (pos + color, used for all solid shapes) ---------------

struct PosColorVertex {
    float x, y;
    uint32_t abgr;  // bgfx packed color (0xAABBGGRR)
};

static bgfx::VertexLayout s_posColorLayout;
static bool               s_layoutInit = false;

// ---- Scissor stack (file-scope; submitTriangles is static) ---------------
struct ScissorEntry { uint16_t x, y, w, h; };
static ScissorEntry s_scissorStack[16];
static int          s_scissorTop = 0;

static void ensureLayout() {
    if (s_layoutInit) return;
    s_posColorLayout.begin()
        .add(bgfx::Attrib::Position, 2, bgfx::AttribType::Float)
        .add(bgfx::Attrib::Color0,   4, bgfx::AttribType::Uint8, true)
        .end();
    s_layoutInit = true;
}

